{{ if eq .chezmoi.os "windows" -}}
$ErrorActionPreference = "Stop"

if ($PSVersionTable.PSEdition -ne "Core") {
    $pwsh = Get-Command pwsh -ErrorAction SilentlyContinue
    if (-not $pwsh) {
        throw "[chezmoi] PowerShell 7 (pwsh) is required. Install it with: winget install --id Microsoft.PowerShell --exact --source winget"
    }

    & $pwsh.Source -NoProfile -ExecutionPolicy Bypass -File $PSCommandPath
    exit $LASTEXITCODE
}

$profileContent = @'
# Managed by chezmoi.
$env:EDITOR = "nvim"
$env:VISUAL = $env:EDITOR

$env:FZF_DEFAULT_COMMAND = "fd --type f --hidden --follow --exclude .git"
$env:FZF_CTRL_T_COMMAND = $env:FZF_DEFAULT_COMMAND
$env:FZF_ALT_C_COMMAND = "fd --type d --hidden --follow --exclude .git"
$env:FZF_DEFAULT_OPTS = @"
--height=40% --layout=reverse
--border --margin=1
--ansi --tabstop=2
--info=inline
--preview-window=right,60%,border
"@

if (Get-Command mise -ErrorAction SilentlyContinue) {
    (& mise activate pwsh) | Out-String | Invoke-Expression
}

if (Get-Command zoxide -ErrorAction SilentlyContinue) {
    (& zoxide init powershell) | Out-String | Invoke-Expression
}

if (Get-Command starship -ErrorAction SilentlyContinue) {
    (& starship init powershell) | Out-String | Invoke-Expression
}

if (Get-Module -ListAvailable -Name PSReadLine) {
    Import-Module PSReadLine
    Set-PSReadLineOption -EditMode Vi
    Set-PSReadLineOption -HistoryNoDuplicates

    if ($Host.Name -eq "ConsoleHost" -and -not [Console]::IsOutputRedirected) {
        try {
            Set-PSReadLineOption -PredictionSource HistoryAndPlugin
            Set-PSReadLineOption -PredictionViewStyle InlineView
        } catch {
            Write-Verbose "PSReadLine prediction is unavailable in this host: $($_.Exception.Message)"
        }
    }
}

if (Get-Module -ListAvailable -Name PSFzf) {
    Import-Module PSFzf
    Set-PsFzfOption -PSReadlineChordProvider "Ctrl+t" -PSReadlineChordReverseHistory "Ctrl+r"
}

function Get-NeovimCommand {
    $nvim = Get-Command nvim -ErrorAction SilentlyContinue
    if ($nvim) {
        return $nvim.Source
    }

    $candidates = @(
        "$env:ProgramFiles\Neovim\bin\nvim.exe",
        "$env:LOCALAPPDATA\Programs\Neovim\bin\nvim.exe"
    )

    foreach ($candidate in $candidates) {
        if (Test-Path $candidate) {
            return $candidate
        }
    }

    throw "nvim was not found. Restart PowerShell after installing Neovim, or verify that Neovim is installed."
}

function vim {
    & (Get-NeovimCommand) @args
}

function vi {
    & (Get-NeovimCommand) @args
}

if (Get-Command lazygit -ErrorAction SilentlyContinue) {
    Set-Alias lg lazygit
}

if (Get-Command bat -ErrorAction SilentlyContinue) {
    Set-Alias cat bat
    $env:FZF_PREVIEW_CMD = "bat --style=plain --color=always --line-range=:500 {}"
}

function l {
    if (Get-Command eza -ErrorAction SilentlyContinue) {
        eza @args
    } else {
        Get-ChildItem @args
    }
}

function la {
    if (Get-Command eza -ErrorAction SilentlyContinue) {
        eza -a @args
    } else {
        Get-ChildItem -Force @args
    }
}

function ll {
    if (Get-Command eza -ErrorAction SilentlyContinue) {
        eza -lah @args
    } else {
        Get-ChildItem -Force @args
    }
}

function Edit-FzfFile {
    if (-not (Get-Command fzf -ErrorAction SilentlyContinue)) {
        Write-Error "Edit-FzfFile requires fzf."
        return
    }

    $source = if (Get-Command fd -ErrorAction SilentlyContinue) {
        fd --type f --hidden --follow --exclude .git
    } elseif (Get-Command rg -ErrorAction SilentlyContinue) {
        rg --files --hidden --follow --no-ignore-vcs
    } else {
        Get-ChildItem -Recurse -File | ForEach-Object FullName
    }

    $preview = if ($env:FZF_PREVIEW_CMD) { $env:FZF_PREVIEW_CMD } else { "type {}" }
    $pick = $source | fzf --preview $preview
    if ($pick) {
        & $env:EDITOR -- $pick
    }
}

function Invoke-FzfLiveGrep {
    if (-not (Get-Command rg -ErrorAction SilentlyContinue)) {
        Write-Error "Invoke-FzfLiveGrep requires ripgrep."
        return
    }

    if (-not (Get-Command fzf -ErrorAction SilentlyContinue)) {
        Write-Error "Invoke-FzfLiveGrep requires fzf."
        return
    }

    $preview = if (Get-Command bat -ErrorAction SilentlyContinue) {
        "bat --style=plain --color=always --line-range=:500 --highlight-line {2} {1}"
    } else {
        "powershell -NoProfile -Command Get-Content -TotalCount 200 {1}"
    }

    $selection = rg --line-number --no-heading --color=always --hidden --glob "!.git" "" |
        fzf --ansi --disabled --phony --query "" `
            --prompt "RG> " `
            --preview $preview `
            --preview-window "right,60%,border" `
            --delimiter ":" `
            --bind "change:reload:rg --line-number --no-heading --color=always --hidden --glob !.git {q} || exit 0" `
            --bind "enter:accept"

    if ($selection -match "^(.*?):(\d+):") {
        & $env:EDITOR "+$($Matches[2])" -- $Matches[1]
    }
}

if (Get-Module -Name PSReadLine) {
    Set-PSReadLineKeyHandler -Chord Ctrl+f -ScriptBlock { Edit-FzfFile }
    Set-PSReadLineKeyHandler -Chord Ctrl+g -ScriptBlock { Invoke-FzfLiveGrep }
}
'@

$profilePath = $PROFILE.CurrentUserCurrentHost
$profileDir = Split-Path -Parent $profilePath
New-Item -ItemType Directory -Path $profileDir -Force | Out-Null

if (Test-Path $profilePath) {
    $existing = Get-Content -Path $profilePath -Raw
    if ($existing -eq $profileContent) {
        Write-Host "[chezmoi] PowerShell profile is already up to date at $profilePath."
        exit 0
    }

    if ($existing -notmatch "Managed by chezmoi") {
        $backup = "$profilePath.bak.$(Get-Date -Format 'yyyyMMddHHmmss')"
        Write-Host "[chezmoi] Backing up existing PowerShell profile to $backup..."
        Copy-Item -Path $profilePath -Destination $backup
    }
}

Set-Content -Path $profilePath -Value $profileContent -Encoding utf8
Write-Host "[chezmoi] Installed PowerShell profile to $profilePath."
{{ end -}}
